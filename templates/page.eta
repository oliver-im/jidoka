<!DOCTYPE html>
<html lang="en" data-theme="light">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Topology: <%= it.task_summary %></title>
  <style><%= it.css %></style>
  <script src="https://cdn.jsdelivr.net/npm/mermaid@11.12.2/dist/mermaid.min.js"></script>
  <% if (it.has_plan) { %>
  <script src="https://cdn.jsdelivr.net/npm/marked@15.0.7/marked.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/dompurify@3.2.4/dist/purify.min.js"></script>
  <% } %>
</head>
<body class="<% if (it.has_plan) { %>has-plan<% } else { %>no-plan<% } %>">

  <header>
    <h1><%= it.task_summary %></h1>
    <div class="header-meta">
      <span class="mode-badge">Mode: <%= it.mode_label %></span>
      <div class="header-actions">
        <button id="theme-toggle" type="button" title="Toggle dark mode">
          <span class="icon-light">&#9788;</span>
          <span class="icon-dark">&#9790;</span>
        </button>
        <button id="download-png" type="button" title="Download as PNG">&#8681; PNG</button>
      </div>
    </div>
  </header>

  <main>
    <% if (it.has_plan) { %>
    <aside class="plan-panel">
      <h2>Plan</h2>
      <div id="plan-content"></div>
    </aside>
    <% } %>

    <section class="diagram-panel">
      <div class="diagrams">
        <% it.mermaid_graphs.forEach((graph, idx) => { %>
        <div class="diagram-block">
          <% if (it.phase_labels.length > 0) { %>
          <h3 class="phase-label"><%= it.phase_labels[idx] %></h3>
          <% } %>
          <pre class="mermaid"><%= graph %></pre>
        </div>
        <% }); %>
      </div>

      <div class="legend">
        <h3>Legend</h3>
        <div class="legend-grid">
          <div class="legend-section">
            <h4>Model</h4>
            <div class="legend-items">
              <div class="legend-item">
                <span class="swatch swatch-haiku"></span> haiku
              </div>
              <div class="legend-item">
                <span class="swatch swatch-sonnet"></span> sonnet
              </div>
              <div class="legend-item">
                <span class="swatch swatch-opus"></span> opus
              </div>
              <div class="legend-item">
                <span class="swatch swatch-main"></span> main agent
              </div>
            </div>
          </div>
          <div class="legend-section">
            <h4>Output</h4>
            <div class="legend-items">
              <div class="legend-item">
                <span class="shape shape-rect"></span> inline
              </div>
              <div class="legend-item">
                <span class="shape shape-pill"></span> file
              </div>
            </div>
          </div>
        </div>
      </div>

      <div class="overview">
        <h3>Topology Overview</h3>
        <pre class="overview-text"><%= it.description %></pre>
      </div>
    </section>
  </main>

  <% if (it.has_plan) { %>
  <script>window.__planMarkdown = <%= it.plan_markdown_json %>;</script>
  <% } %>
  <script><%= it.js %></script>
</body>
</html>
