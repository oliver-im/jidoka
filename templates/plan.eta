<!DOCTYPE html>
<html lang="en" data-theme="light">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Plan: <%= it.title %></title>
  <style><%= it.css %></style>
  <script src="https://cdn.jsdelivr.net/npm/mermaid@11.12.2/dist/mermaid.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/marked@15.0.7/marked.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/dompurify@3.2.4/dist/purify.min.js"></script>
</head>
<body class="plan">
  <header>
    <h1>Plan: <%= it.title %></h1>
    <div class="header-meta">
      <span class="mode-badge"><%= it.unit_count %> unit<%= it.unit_count_suffix %><% if (it.topology_count > 0) { %> · <%= it.topology_count %> with topology<% } %></span>
      <div class="header-actions">
        <button id="theme-toggle" type="button" title="Toggle dark mode">
          <span class="icon-light">&#9788;</span>
          <span class="icon-dark">&#9790;</span>
        </button>
      </div>
    </div>
  </header>

  <main class="plan-main">
    <aside class="plan-toc">
      <h2>Units</h2>
      <ul>
        <% it.units.forEach((unit) => { %>
        <li><a href="#<%= unit.anchor %>"><span class="unit-prefix"><%= unit.prefix %></span> <%= unit.title %></a></li>
        <% }); %>
      </ul>
    </aside>

    <section class="plan-content">
      <article class="plan-overview-card" id="overview">
        <h2>Overview</h2>
        <div id="overview-md" class="markdown-body"></div>
      </article>

      <% it.units.forEach((unit) => { %>
      <article class="unit-card" id="<%= unit.anchor %>">
        <header class="unit-header">
          <h2>Unit <%= unit.prefix %> — <%= unit.title %></h2>
          <div class="unit-chips">
            <span class="chip chip-blocked-by">Blocked by: <%= unit.blocked_by_label %></span>
            <span class="chip chip-agents"><%= unit.agents_label %></span>
            <% if (unit.has_topology) { %>
            <span class="chip chip-topology">topology</span>
            <% } %>
          </div>
        </header>

        <p class="unit-summary"><%= unit.summary %></p>

        <div class="unit-body markdown-body" data-key="<%= unit.index %>"></div>

        <% unit.mermaid_graphs.forEach((graph) => { %>
        <div class="diagram-block">
          <pre class="mermaid"><%= graph %></pre>
        </div>
        <% }); %>

        <% if (unit.review_steps.length > 0) { %>
        <div class="unit-review">
          <h3>Review pipeline</h3>
          <ul>
            <% unit.review_steps.forEach((step) => { %>
            <li>
              <code><%= step.primary %></code>
              <% if (step.note) { %>
              <div class="review-note"><em><%= step.note %></em></div>
              <% } %>
            </li>
            <% }); %>
          </ul>
        </div>
        <% } %>

        <div class="unit-footer"><a href="#overview">↑ overview</a></div>
      </article>
      <% }); %>
    </section>
  </main>

  <script>
    window.__overviewMarkdown = <%= it.overview_markdown_json %>;
    window.__unitBodies = <%= it.unit_bodies_json %>;
  </script>
  <script><%= it.js %></script>
</body>
</html>
