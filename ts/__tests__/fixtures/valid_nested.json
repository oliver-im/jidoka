{
  "task_summary": "Implement feature with sub-tasks",
  "execution_mode": "subagents",
  "agents": [
    {
      "id": "researcher",
      "role": "Research the problem",
      "model": "haiku",
      "tools": ["Read", "Grep"],
      "blocked_by": [],
      "background": false
    },
    {
      "id": "implementer",
      "role": "Implement the solution",
      "model": "opus",
      "tools": ["Read", "Write"],
      "blocked_by": ["researcher"],
      "background": false,
      "execution_mode": "subagents",
      "agents": [
        {
          "id": "coder",
          "role": "Write the code",
          "model": "sonnet",
          "tools": ["Write"],
          "blocked_by": [],
          "background": false,
          "output": {"file": "src/feature.rs"},
          "produces": "feature code"
        },
        {
          "id": "tester",
          "role": "Write tests",
          "model": "haiku",
          "tools": ["Write"],
          "blocked_by": ["coder"],
          "background": false,
          "output": {"file": "tests/feature_test.rs"},
          "produces": "test suite"
        }
      ]
    }
  ]
}
