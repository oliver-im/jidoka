{
  "description": "Materialize plan-mode output as a reviewable plan directory on ExitPlanMode.",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "ExitPlanMode",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/dist/cli.js\" hook"
          }
        ]
      }
    ]
  }
}
